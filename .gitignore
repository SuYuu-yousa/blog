# Dependencies
node_modules/

# Astro output and generated state
dist/
.astro/

# Environment and local-only config
.env
.env.*
!.env.example

# Obsidian volatile workspace state
obsidian/.obsidian/workspace.json
obsidian/.obsidian/workspace-mobile.json

# Obsidian plugin runtime files are local installs.
obsidian/.obsidian/plugins/*/main.js
obsidian/.obsidian/plugins/*/styles.css
obsidian/.obsidian/plugins/*/manifest.json
obsidian/.obsidian/plugins/*/obsidian_askpass.sh

# Local private notes that should not sync or publish.
obsidian/private/

# Generated publishing targets. Source of truth is obsidian/posts.
src/content/blog-zh/*.md
src/content/blog-zh/assets/*
!src/content/blog-zh/assets/.gitkeep

# OS/editor noise
.DS_Store
Thumbs.db
