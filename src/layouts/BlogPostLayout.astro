---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';

interface Props {
  post: CollectionEntry<'blog-zh'>;
}

const { post } = Astro.props;
const { title, description } = post.data;
---

<BaseLayout title={`${title} | D:\blog`} description={description || title}>
  <article class="prose">
    <header class="mb-8 border-b border-[var(--line)] pb-6">
      <h1 class="mb-3 text-4xl font-bold">{title}</h1>
      {description && <p class="text-lg text-[var(--muted)]">{description}</p>}
    </header>
    <slot />
  </article>
</BaseLayout>
