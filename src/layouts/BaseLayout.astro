---
import '../styles/global.css';
import { withBase } from '@/lib/paths';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A personal blog built with Astro.' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
    <title>{title}</title>
  </head>
  <body>
    <header class="border-b border-[var(--line)]">
      <nav class="mx-auto flex max-w-5xl items-center justify-between px-5 py-4">
        <a class="text-lg font-semibold no-underline" href={withBase()}>D:\blog</a>
        <div class="flex gap-5 text-sm text-[var(--muted)]">
          <a href={withBase('zh/blog/')}>文章</a>
          <a href={withBase('about/')}>关于</a>
        </div>
      </nav>
    </header>
    <main class="mx-auto max-w-5xl px-5 py-10">
      <slot />
    </main>
    <footer class="mx-auto max-w-5xl px-5 py-8 text-sm text-[var(--muted)]">
      <p>Built with Astro. Deploy-ready for Cloudflare Pages.</p>
    </footer>
  </body>
</html>
