---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';

const posts = (await getCollection('blog-zh'))
  .filter((post) => !post.data.draft && post.data.lang === 'zh')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="D:\blog" description="一个使用 Astro 搭建的个人博客。">
  <section class="grid gap-10 md:grid-cols-[1.1fr_0.9fr] md:items-end">
    <div>
      <p class="mb-3 text-sm font-medium uppercase text-[var(--accent)]">Personal publishing</p>
      <h1 class="max-w-3xl text-5xl font-bold leading-tight">一个轻量、低成本、内容优先的博客。</h1>
      <p class="mt-5 max-w-2xl text-lg text-[var(--muted)]">
        用 Markdown 写作，Astro 生成静态页面，之后可以部署到 Cloudflare Pages。
      </p>
      <div class="mt-8 flex gap-3">
        <a class="rounded-md bg-[var(--accent)] px-4 py-2 font-medium text-[var(--accent-ink)] no-underline" href="/zh/blog/">阅读文章</a>
        <a class="rounded-md border border-[var(--line)] px-4 py-2 font-medium no-underline" href="/about/">关于我</a>
      </div>
    </div>
    <div class="border-l border-[var(--line)] pl-6 text-sm text-[var(--muted)]">
      <p>Stack</p>
      <p class="mt-2 text-2xl font-semibold text-[var(--ink)]">Astro 5 / Tailwind 4 / Markdown</p>
    </div>
  </section>

  <section class="mt-16">
    <div class="mb-5 flex items-baseline justify-between gap-4">
      <h2 class="text-2xl font-semibold">最新文章</h2>
      <a class="text-sm text-[var(--muted)]" href="/zh/blog/">全部文章</a>
    </div>
    <div class="grid gap-4">
      {
        posts.map((post) => (
          <a class="block rounded-md border border-[var(--line)] p-5 no-underline transition hover:border-[var(--accent)]" href={`/zh/blog/${post.slug}/`}>
            <h3 class="text-xl font-semibold">{post.data.title}</h3>
            <p class="mt-2 text-[var(--muted)]">{post.data.description}</p>
            <time class="mt-3 block text-sm text-[var(--muted)]" datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('zh-CN')}
            </time>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
