---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { withBase } from '@/lib/paths';

const posts = (await getCollection('blog-zh'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => a.data.order - b.data.order || a.data.title.localeCompare(b.data.title, 'zh-CN'))
  .slice(0, 3);
---

<BaseLayout title="D:\blog" description="一个使用 Astro 搭建的个人博客。">
  <section class="grid gap-10 md:grid-cols-[1.1fr_0.9fr] md:items-end">
    <div>
      <p class="mb-3 text-sm font-medium uppercase text-[var(--accent)]">Personal publishing</p>
      <h1 class="max-w-3xl text-5xl font-bold leading-tight">一个轻量、低成本、内容优先的博客。</h1>
      <p class="mt-5 max-w-2xl text-lg text-[var(--muted)]">
        在 Obsidian 里自然写作，发布脚本会整理成可以部署的 Astro 静态页面。
      </p>
      <div class="mt-8 flex gap-3">
        <a class="rounded-md bg-[var(--accent)] px-4 py-2 font-medium text-[var(--accent-ink)] no-underline" href={withBase('zh/blog/')}>阅读文章</a>
        <a class="rounded-md border border-[var(--line)] px-4 py-2 font-medium no-underline" href={withBase('about/')}>关于我</a>
      </div>
    </div>
    <div class="border-l border-[var(--line)] pl-6 text-sm text-[var(--muted)]">
      <p>Stack</p>
      <p class="mt-2 text-2xl font-semibold text-[var(--ink)]">Astro 5 / Tailwind 4 / Obsidian</p>
    </div>
  </section>

  <section class="mt-16">
    <div class="mb-5 flex items-baseline justify-between gap-4">
      <h2 class="text-2xl font-semibold">最新文章</h2>
      <a class="text-sm text-[var(--muted)]" href={withBase('zh/blog/')}>全部文章</a>
    </div>
    <div class="grid gap-4">
      {
        posts.map((post) => (
          <a class="block rounded-md border border-[var(--line)] p-5 no-underline transition hover:border-[var(--accent)]" href={withBase(`zh/blog/${post.slug}/`)}>
            <h3 class="text-xl font-semibold">{post.data.title}</h3>
            {post.data.description && <p class="mt-2 text-[var(--muted)]">{post.data.description}</p>}
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
